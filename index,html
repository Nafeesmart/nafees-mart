<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nafees Mart - Online Shopping</title>
    <style>
        /* Basic Styling */
        body { font-family: Arial, sans-serif; margin: 0; padding: 0; background-color: #f4f4f4; }
        header { background: #232f3e; color: white; padding: 15px; text-align: center; }
        nav { background: #37475a; padding: 10px; text-align: center; }
        nav a { color: white; margin: 0 15px; text-decoration: none; }
        
        .container { padding: 20px; display: flex; flex-wrap: wrap; justify-content: center; }
        
        /* Product Card */
        .product-card { 
            background: white; border: 1px solid #ddd; margin: 10px; padding: 15px; 
            width: 250px; text-align: center; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        .product-card img { max-width: 100%; height: 200px; object-fit: cover; }
        .price { color: #B12704; font-size: 1.2rem; font-weight: bold; margin: 10px 0; }
        
        .buy-btn { 
            background: #ffd814; border: none; padding: 10px 20px; 
            cursor: pointer; border-radius: 20px; font-weight: bold; width: 100%;
        }
        .buy-btn:hover { background: #f7ca00; }
        
        footer { background: #232f3e; color: white; text-align: center; padding: 20px; margin-top: 20px; }
    </style>
</head>
<body>

<header>
    <h1>Nafees Mart</h1>
    <p>Apki Zarurat, Hamari Zimmedari</p>
</header>

<nav>
    <a href="#">Home</a>
    <a href="#">Products</a>
    <a href="#">Contact Us</a>
</nav>

<div class="container">
    <div class="product-card">
        <img src="https://via.placeholder.com/200" alt="Product 1">
        <h3>Smart Watch</h3>
        <p class="price">Rs. 2,500 PKR</p>
        <button class="buy-btn" onclick="orderNow('Smart Watch', '2500')">WhatsApp per Order Karein</button>
    </div>

    <div class="product-card">
        <img src="https://via.placeholder.com/200" alt="Product 2">
        <h3>Wireless Earbuds</h3>
        <p class="price">Rs. 1,800 PKR</p>
        <button class="buy-btn" onclick="orderNow('Wireless Earbuds', '1800')">WhatsApp per Order Karein</button>
    </div>

    <div class="product-card">
        <img src="https://via.placeholder.com/200" alt="Product 3">
        <h3>Power Bank</h3>
        <p class="price">Rs. 3,200 PKR</p>
        <button class="buy-btn" onclick="orderNow('Power Bank', '3200')">WhatsApp per Order Karein</button>
    </div>
</div>

<footer>
    <p>&copy; 2024 Nafees Mart - All Rights Reserved</p>
</footer>

<script>
    function orderNow(name, price) {
        // Apna WhatsApp Number yahan likhein (92 ke sath)
        var phoneNumber = "923001234567"; 
        var message = "Assalam-o-Alaikum, Mujha '" + name + "' order karni hai. Price: Rs. " + price + " PKR.";
        var url = "https://wa.me/" + phoneNumber + "?text=" + encodeURIComponent(message);
        window.open(url, '_blank');
    }
</script>

</body>
</html>
